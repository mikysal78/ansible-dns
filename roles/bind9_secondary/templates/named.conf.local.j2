// named.conf.local — SECONDARY
// Generato da Ansible — NON MODIFICARE MANUALMENTE

// La chiave TSIG axfr serve per autenticare l'AXFR verso il primary.
// Inclusa qui perché è referenziata nel blocco masters sottostante.
include "{{ bind_config_dir }}/tsig-axfr.key";

{% for zone in dns_zones %}
zone "{{ zone.name }}" {
    type slave;
    file "/var/cache/bind/db.{{ zone.name }}";
    masters {
        {{ dns_primary_ip }} key "{{ dns_tsig_key_name }}";
    };
    allow-notify { {{ dns_primary_ip }}; };
    allow-transfer { none; };
};

{% endfor %}
