// named.conf.options — PRIMARY (hidden)
// Generato da Ansible — NON MODIFICARE MANUALMENTE

include "{{ bind_config_dir }}/tsig-axfr.key";
include "{{ bind_config_dir }}/ddns.key";

{% if bind_dnssec_policy | default('') != '' %}
// ============================================================
// DNSSEC Policy — definita anche qui perché named.conf.local
// la referenzia per zona: la config deve essere valida anche
// PRIMA che il role dnssec ridepioyi le options (named-checkconf
// pre-reload fallirebbe tra i due role). I parametri sono gli
// stessi default del role dnssec.
// ============================================================
dnssec-policy "{{ bind_dnssec_policy }}" {
    signatures-validity          {{ dnssec_sig_validity | default('P14D') }};
    signatures-validity-dnskey   {{ dnssec_sig_validity | default('P14D') }};
    signatures-refresh           {{ dnssec_sig_refresh | default('P3D') }};

    keys {
        ksk lifetime {{ dnssec_ksk_lifetime | default('P1Y') }} algorithm {{ dnssec_ksk_algorithm | default('ecdsap256sha256') }};
        zsk lifetime {{ dnssec_zsk_lifetime | default('P90D') }} algorithm {{ dnssec_zsk_algorithm | default('ecdsap256sha256') }};
    };

{% if dnssec_use_nsec3 | default(true) %}
    nsec3param iterations {{ dnssec_nsec3_iterations | default(0) }} optout no salt-length {{ dnssec_nsec3_salt_length | default(0) }};
{% endif %}
};
{% endif %}

acl "secondaries" {
{% for ip in dns_secondary_peer_ips %}
    {{ ip }};
{% endfor %}
};

acl "ddns-clients" {
    // Router OpenWrt autorizzati al DDNS
    // Aggiungi qui gli IP pubblici dei router se fissi,
    // altrimenti lascia any e affidati alla TSIG key
    any;
};

options {
    directory "/var/cache/bind";
    pid-file "/run/named/named.pid";

    listen-on    { 127.0.0.1; {{ dns_primary_ip }};{% if dns_primary_lan_ip | default('') != '' %} {{ dns_primary_lan_ip }};{% endif %} };
    listen-on-v6 { none; };

    // Hidden primary: NON risponde a query esterne
    allow-query         { localhost; secondaries; };
    allow-query-cache   { localhost; };
    allow-transfer      { key "{{ dns_tsig_key_name }}"; };
    allow-update        { key "{{ ddns_key_name }}"; };

    // Notifica i secondari ad ogni cambio zona
    notify explicit;
    notify-source {{ dns_primary_ip }};
    also-notify {
{% for ip in dns_secondary_peer_ips %}
        {{ ip }};
{% endfor %}
    };

    recursion yes;
    allow-recursion { localhost; };

    dnssec-validation {{ bind_dnssec_validation }};
    querylog {{ bind_querylog }};

    // Limiti di trasferimento
    transfers-out {{ bind_transfers_out }};

    // Sicurezza: nasconde versione
    version "not available";

    // Logging
    statistics-file "{{ bind_log_dir }}/named_stats.txt";
};

logging {
    channel default_log {
        file "{{ bind_log_dir }}/named.log" versions 5 size 10m;
        severity dynamic;
        print-time yes;
        print-severity yes;
        print-category yes;
    };
    channel ddns_log {
        file "{{ bind_log_dir }}/ddns.log" versions 3 size 5m;
        severity info;
        print-time yes;
    };
    category default      { default_log; };
    category update       { ddns_log; };
    category update-security { ddns_log; };
    category security     { default_log; };
    category xfer-in      { default_log; };
    category xfer-out     { default_log; };
};
