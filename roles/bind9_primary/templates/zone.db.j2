; ============================================================
; Zona: {{ zone_data.zone.name }}
; Generata da Ansible da file YAML — NON MODIFICARE MANUALMENTE
; ============================================================

$ORIGIN {{ zone_data.zone.name }}.
$TTL    {{ zone_data.zone.ttl | default(3600) }}

; --- SOA ---
@   IN  SOA {{ zone_data.zone.soa.primary_ns }} {{ zone_data.zone.soa.admin }} (
                {{ zone_serial_override | default(ansible_facts.date_time.date | replace("-","") ~ "01") }} ; serial YYYYMMDDNN
                {{ zone_data.zone.soa.refresh  | default(7200)   }} ; refresh
                {{ zone_data.zone.soa.retry    | default(3600)   }} ; retry
                {{ zone_data.zone.soa.expire   | default(1209600)}} ; expire
                {{ zone_data.zone.soa.minimum  | default(300)    }} ; minimum TTL
            )

; --- NS ---
{% for ns in zone_data.zone.ns | default([]) %}
@   IN  NS  {{ ns }}
{% endfor %}

; --- A ---
{# Supporta ip come scalare o lista (round-robin / multi-homing) #}
{% for r in zone_data.zone.a | default([]) %}
{% set ips = r.ip if (r.ip is iterable and r.ip is not string) else [r.ip] %}
{% for addr in ips %}
{{ '%-30s' | format(r.name) }} {% if r.ttl is defined %}{{ r.ttl }}{% else %}{{ zone_data.zone.ttl | default(3600) }}{% endif %} IN  A       {{ addr }}
{% endfor %}
{% endfor %}

; --- AAAA ---
{# AAAA da campo ipv6 (scalare o lista) sui record A #}
{% for r in zone_data.zone.a | default([]) %}
{% if r.ipv6 is defined %}
{% set v6s = r.ipv6 if (r.ipv6 is iterable and r.ipv6 is not string) else [r.ipv6] %}
{% for addr in v6s %}
{{ '%-30s' | format(r.name) }} {% if r.ttl is defined %}{{ r.ttl }}{% else %}{{ zone_data.zone.ttl | default(3600) }}{% endif %} IN  AAAA    {{ addr }}
{% endfor %}
{% endif %}
{% endfor %}
{# AAAA da lista dedicata (retrocompatibilità) #}
{% for r in zone_data.zone.aaaa | default([]) %}
{{ '%-30s' | format(r.name) }} {% if r.ttl is defined %}{{ r.ttl }}{% else %}{{ zone_data.zone.ttl | default(3600) }}{% endif %} IN  AAAA    {{ r.ip }}
{% endfor %}

; --- CNAME (da record cname dedicati + aliases sui record A) ---
{% for r in zone_data.zone.a | default([]) %}
{% for alias in r.aliases | default([]) %}
{{ '%-30s' | format(alias) }} {{ zone_data.zone.ttl | default(3600) }} IN  CNAME   {{ r.name }}
{% endfor %}
{% endfor %}
{% for r in zone_data.zone.cname | default([]) %}
{{ '%-30s' | format(r.name) }} {{ zone_data.zone.ttl | default(3600) }} IN  CNAME   {{ r.target }}
{% endfor %}

; --- MX ---
{% for r in zone_data.zone.mx | default([]) %}
@   {{ zone_data.zone.ttl | default(3600) }} IN  MX      {{ r.priority }} {{ r.host }}
{% endfor %}

; --- TXT ---
{% for r in zone_data.zone.txt | default([]) %}
{{ '%-30s' | format(r.name) }} {{ zone_data.zone.ttl | default(3600) }} IN  TXT     "{{ r.value }}"
{% endfor %}

; --- SRV ---
{% for r in zone_data.zone.srv | default([]) %}
{{ '%-30s' | format(r.name) }} {{ zone_data.zone.ttl | default(3600) }} IN  SRV     {{ r.priority }} {{ r.weight }} {{ r.port }} {{ r.target }}
{% endfor %}

; --- CAA ---
{% for r in zone_data.zone.caa | default([]) %}
{{ '%-30s' | format(r.name) }} {{ zone_data.zone.ttl | default(3600) }} IN  CAA     {{ r.flag }} {{ r.tag }} "{{ r.value }}"
{% endfor %}

; --- TLSA ---
{% for r in zone_data.zone.tlsa | default([]) %}
{{ '%-30s' | format(r.name) }} {{ zone_data.zone.ttl | default(3600) }} IN  TLSA    {{ r.usage }} {{ r.selector }} {{ r.matching }} {{ r.certificate_hash }}
{% endfor %}

; --- SSHFP ---
{% for r in zone_data.zone.sshfp | default([]) %}
{{ '%-30s' | format(r.name) }} {{ zone_data.zone.ttl | default(3600) }} IN  SSHFP   {{ r.algorithm }} {{ r.type }} {{ r.fingerprint }}
{% endfor %}

; --- PTR (zone reverse) ---
{% for r in zone_data.zone.ptr | default([]) %}
{{ '%-30s' | format(r.last_octet) }} {{ zone_data.zone.ttl | default(3600) }} IN  PTR     {{ r.fqdn }}
{% endfor %}
