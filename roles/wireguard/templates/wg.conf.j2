# ============================================================
# WireGuard {{ wg_interface }} — generato da Ansible
# Host: {{ inventory_hostname }} ({{ wg_address }})
# NON MODIFICARE MANUALMENTE
# ============================================================
[Interface]
Address = {{ wg_address }}/24
PrivateKey = {{ wg_private_key }}
{% if 'dns_secondary' in group_names or 'proxmox' in group_names %}
ListenPort = {{ wg_port }}
{% endif %}

{% if 'dns_primary' in group_names %}
{# Il primary lista TUTTI i secondari come peer, con endpoint pubblico + keepalive #}
{% for host in groups['dns_secondary'] %}
# Peer: {{ host }}
[Peer]
PublicKey = {{ hostvars[host]['wg_public_key'] }}
Endpoint = {{ hostvars[host]['ansible_host'] }}:{{ wg_port }}
AllowedIPs = {{ hostvars[host]['wg_address'] }}/32
PersistentKeepalive = {{ wg_keepalive }}

{% endfor %}
{# Peer extra sulla stessa LAN (es. Proxmox host, per l'ACME built-in via nsupdate):
   stessa logica dei secondari, endpoint fisso + keepalive, ma senza NAT da attraversare #}
{% for host in groups['proxmox'] | default([]) %}
{% if hostvars[host]['wg_address'] is defined %}
# Peer: {{ host }} (Proxmox host — LAN, ACME built-in via nsupdate)
[Peer]
PublicKey = {{ hostvars[host]['wg_public_key'] }}
Endpoint = {{ hostvars[host]['ansible_host'] }}:{{ wg_port }}
AllowedIPs = {{ hostvars[host]['wg_address'] }}/32
PersistentKeepalive = {{ wg_keepalive }}

{% endif %}
{% endfor %}
{% else %}
{# I secondari (e Proxmox) listano SOLO il primary come peer (no endpoint: è dietro NAT, si connette lui) #}
{% set primary = groups['dns_primary'][0] %}
# Peer: {{ primary }} (hidden primary, dietro NAT)
[Peer]
PublicKey = {{ hostvars[primary]['wg_public_key'] }}
AllowedIPs = {{ hostvars[primary]['wg_address'] }}/32

{% endif %}
