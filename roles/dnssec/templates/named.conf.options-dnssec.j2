// named.conf.options — PRIMARY con DNSSEC inline signing
// Generato da Ansible — NON MODIFICARE MANUALMENTE

include "{{ bind_config_dir }}/tsig-axfr.key";
include "{{ bind_config_dir }}/ddns.key";

// ============================================================
// DNSSEC Policy — inline signing automatico
// BIND 9.16+ gestisce rotazione KSK/ZSK, firma, NSEC3
// ============================================================
dnssec-policy "{{ dnssec_policy_name }}" {

    // Durata validità firme RRSIG
    signatures-validity          {{ dnssec_sig_validity }};
    signatures-validity-dnskey   {{ dnssec_sig_validity }};
    signatures-refresh           {{ dnssec_sig_refresh }};

    // KSK — chiave di lunga durata, firma i DNSKEY record
    keys {
        ksk lifetime {{ dnssec_ksk_lifetime }} algorithm {{ dnssec_ksk_algorithm }};
        zsk lifetime {{ dnssec_zsk_lifetime }} algorithm {{ dnssec_zsk_algorithm }};
    };

{% if dnssec_use_nsec3 %}
    // NSEC3 — oscura l'enumerazione della zona
    // iterations=0 e salt vuoto: RFC 9276 raccomanda questi valori
    nsec3param iterations {{ dnssec_nsec3_iterations }} optout no salt-length {{ dnssec_nsec3_salt_length }};
{% endif %}
};

acl "secondaries" {
{% for ip in dns_secondary_peer_ips %}
    {{ ip }};
{% endfor %}
};

options {
    directory "/var/cache/bind";
    key-directory "{{ dnssec_key_directory }}";

    listen-on    { 127.0.0.1; {{ dns_primary_ip }}; };
    listen-on-v6 { none; };

    allow-query       { localhost; secondaries; };
    allow-query-cache { localhost; };
    allow-transfer    { key "{{ dns_tsig_key_name }}"; };
    allow-update      { key "{{ ddns_key_name }}"; };

    // NOTIFY solo verso gli IP WireGuard dei secondari: dietro NAT la
    // sorgente verso i loro IP pubblici sarebbe quella della NAT e i
    // secondari (allow-notify { <wg-primary> }) la rifiuterebbero.
    // "explicit" evita anche i NOTIFY agli NS pubblici della zona.
    notify explicit;
    notify-source {{ dns_primary_ip }};
    also-notify {
{% for ip in dns_secondary_peer_ips %}
        {{ ip }};
{% endfor %}
    };

    recursion yes;
    allow-recursion { localhost; };

    // DNSSEC validation abilitata
    dnssec-validation auto;

    // Limita risposte (anti-amplification a livello BIND)
    minimal-responses yes;
    minimal-any yes;

    // Nasconde versione
    version "not available";

    // Performance
    transfers-out {{ bind_transfers_out }};
    max-cache-size 64m;

    statistics-file "{{ bind_log_dir }}/named_stats.txt";
};

logging {
    channel default_log {
        file "{{ bind_log_dir }}/named.log" versions 5 size 20m;
        severity dynamic;
        print-time yes;
        print-severity yes;
        print-category yes;
    };
    channel dnssec_log {
        file "{{ bind_log_dir }}/dnssec.log" versions 3 size 10m;
        severity info;
        print-time yes;
    };
    channel ddns_log {
        file "{{ bind_log_dir }}/ddns.log" versions 3 size 5m;
        severity info;
        print-time yes;
    };
    category default        { default_log; };
    category dnssec         { dnssec_log; };
    category update         { ddns_log; };
    category update-security{ ddns_log; };
    category security       { default_log; };
    category xfer-in        { default_log; };
    category xfer-out       { default_log; };
};
