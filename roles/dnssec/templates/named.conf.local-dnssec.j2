// named.conf.local — PRIMARY con DNSSEC inline signing
// Generato da Ansible — NON MODIFICARE MANUALMENTE

{% for zone in dns_zones %}
zone "{{ zone.name }}" {
    type master;
    file "{{ bind_zones_dir }}/db.{{ zone.name }}";

    // Inline signing: BIND firma automaticamente mantenendo
    // il file raw leggibile e la zona signed in memoria/journal
{% if not zone.ddns_enabled | default(false) %}
    dnssec-policy "{{ dnssec_policy_name }}";
    inline-signing yes;
{% else %}
    // Zona DDNS: inline signing compatibile con aggiornamenti dinamici
    // BIND ri-firma i record aggiornati automaticamente
    dnssec-policy "{{ dnssec_policy_name }}";
    inline-signing yes;
    allow-update { key "{{ ddns_key_name }}"; };
    journal "{{ bind_zones_dir }}/db.{{ zone.name }}.jnl";
{% endif %}

    allow-transfer { key "{{ dns_tsig_key_name }}"; };
    notify yes;
    also-notify {
{% for ip in dns_secondary_ips %}
        {{ ip }};
{% endfor %}
    };
};

{% endfor %}
