# /etc/nftables.d/anti-amplification.nft
# Generato da Ansible — NON MODIFICARE MANUALMENTE
#
# Incluso dalla chain input di inet filter.
# Mitiga gli attacchi di amplification DNS limitando le query
# ad alto rischio e applicando rate limiting per sorgente.

        # Blocca query DNS di tipo ANY (qtype 255), principale vettore di
        # amplification. Il qtype ANY è al byte offset 2 della sezione question
        # (dopo l'header DNS di 12 byte): si verifica @th,offset.
        # Drop di pacchetti UDP/53 che richiedono ANY.
        udp dport 53 @th,240,16 255 drop

        # Rate limit per IP sorgente sulle query UDP/53 (anti-flood).
        udp dport 53 ip saddr != @dns_secondaries \
            meter amp_flood { ip saddr limit rate over {{ nft_dns_rate_limit_pps | default(30) }}/second burst {{ nft_dns_rate_limit_burst | default(50) }} packets } \
            drop
