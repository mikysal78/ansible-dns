# /etc/nftables.d/dns.nft — Regole DNS per PRIMARY (hidden master)
# Generato da Ansible — NON MODIFICARE MANUALMENTE
#
# Il primary è nascosto: accetta DNS solo da localhost e secondari,
# accetta AXFR (TCP) solo dai secondari con TSIG,
# accetta DDNS (UDP+TCP) solo da localhost e router autorizzati.

        # DNS ricorsivo localhost
        udp dport 53 iif lo accept
        tcp dport 53 iif lo accept

        # DNS query dai secondari (per NOTIFY/SOA check)
        udp dport 53 ip saddr @dns_secondaries accept

        # AXFR TCP dai secondari (autenticato via TSIG a livello BIND)
        tcp dport 53 ip saddr @dns_secondaries \
            ct state new limit rate 5/minute burst 10 packets accept

        # DDNS nsupdate: accetta da localhost (acme.sh) e router OpenWrt
        # I router si autenticano via TSIG, il firewall lascia passare per IP
        udp dport 53 ip saddr { {{ (['127.0.0.1'] + (ddns_allowed_sources | default([]))) | join(', ') }} } accept
        tcp dport 53 ip saddr { {{ (['127.0.0.1'] + (ddns_allowed_sources | default([]))) | join(', ') }} } accept

        # Tutto il resto su porta 53 viene droppato silenziosamente
        udp dport 53 drop
        tcp dport 53 drop
{% set _mon_ips = groups['monitoring_server'] | default([])
                  | map('extract', hostvars, 'wg_address') | select('defined') | list %}
{% if _mon_ips | length > 0 %}

        # Exporter Prometheus (node/bind): solo dal monitoring server via WireGuard
        tcp dport { {{ node_exporter_port | default(9100) }}, {{ bind_exporter_port | default(9119) }} } \
            ip saddr { {{ _mon_ips | join(', ') }} } accept
{% endif %}
