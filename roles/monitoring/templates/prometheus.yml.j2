# /opt/prometheus/prometheus.yml
# Generato da Ansible — NON MODIFICARE MANUALMENTE
#
# Gira sul monitoring server (CT dedicato): gli exporter degli host
# DNS vengono scrapati attraverso il tunnel WireGuard (mai via IP
# pubblico), Alertmanager è locale.
{% set _primary = groups['dns_primary'][0] %}

global:
  scrape_interval:     {{ prometheus_scrape_interval }}
  evaluation_interval: {{ prometheus_evaluation_interval }}
  external_labels:
    cluster: "dns-infra"
    environment: "production"

alerting:
  alertmanagers:
    - static_configs:
        - targets:
            - "localhost:{{ alertmanager_port }}"

rule_files:
  - "{{ prometheus_dir }}/rules/*.yml"

scrape_configs:

  # --- Prometheus stesso ---
  - job_name: "prometheus"
    static_configs:
      - targets: ["localhost:{{ prometheus_port }}"]

  # --- node_exporter: monitoring server + tutti i server DNS (via wg) ---
  - job_name: "node"
    static_configs:
      - targets:
          - "localhost:{{ node_exporter_port }}"
        labels:
          role: "monitoring"
          instance: "{{ inventory_hostname }}"
      - targets:
          - "{{ hostvars[_primary]['wg_address'] }}:{{ node_exporter_port }}"
        labels:
          role: "dns_primary"
          instance: "primary"
{% for host in groups['dns_secondary'] %}
      - targets:
          - "{{ hostvars[host]['wg_address'] }}:{{ node_exporter_port }}"
        labels:
          role: "dns_secondary"
          instance: "{{ host }}"
{% endfor %}

  # --- bind_exporter: primary (via wg) ---
  - job_name: "bind_primary"
    static_configs:
      - targets:
          - "{{ hostvars[_primary]['wg_address'] }}:{{ bind_exporter_port }}"
        labels:
          role: "dns_primary"
          instance: "primary"

  # --- bind_exporter: secondari (via wg) ---
  - job_name: "bind_secondary"
    static_configs:
{% for host in groups['dns_secondary'] %}
      - targets:
          - "{{ hostvars[host]['wg_address'] }}:{{ bind_exporter_port }}"
        labels:
          role: "dns_secondary"
          instance: "{{ host }}"
{% endfor %}

  # --- alertmanager ---
  - job_name: "alertmanager"
    static_configs:
      - targets: ["localhost:{{ alertmanager_port }}"]
