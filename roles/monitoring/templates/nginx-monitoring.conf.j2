# /etc/nginx/sites-available/monitoring.conf
# Generato da Ansible — NON MODIFICARE MANUALMENTE
#
# Reverse proxy: smista per nome host verso i servizi in ascolto
# solo su loopback. Un vhost per servizio, tutti sulla :{{ monitoring_proxy_port }}.

# --- Grafana (default_server: anche accesso per IP) ---
server {
    listen {{ monitoring_proxy_port }} default_server;
    server_name {{ grafana_domain }};

    location / {
        proxy_pass http://127.0.0.1:{{ grafana_port }};
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Grafana Live (websocket)
    location /api/live/ {
        proxy_pass http://127.0.0.1:{{ grafana_port }};
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
    }
}

# --- Prometheus ---
server {
    listen {{ monitoring_proxy_port }};
    server_name {{ prometheus_domain }};

    location / {
        proxy_pass http://127.0.0.1:{{ prometheus_port }};
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
    }
}

# --- Alertmanager ---
server {
    listen {{ monitoring_proxy_port }};
    server_name {{ alertmanager_domain }};

    location / {
        proxy_pass http://127.0.0.1:{{ alertmanager_port }};
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
    }
}
