# /opt/alertmanager/alertmanager.yml
# Generato da Ansible — NON MODIFICARE MANUALMENTE

global:
  resolve_timeout: 5m
{% if alertmanager_smtp_enabled %}
  smtp_smarthost: "{{ alertmanager_smtp_host }}"
  smtp_from: "{{ alertmanager_smtp_from }}"
  smtp_auth_username: "{{ alertmanager_smtp_username }}"
  smtp_auth_password: "{{ alertmanager_smtp_password }}"
  smtp_require_tls: true
{% endif %}

templates:
  - "/opt/alertmanager/templates/*.tmpl"

route:
  group_by: ["alertname", "instance", "severity"]
  group_wait: 30s
  group_interval: 5m
  repeat_interval: 4h
  receiver: "default"

  routes:
    - match:
        severity: critical
      receiver: "critical"
      repeat_interval: 1h

    - match:
        severity: warning
      receiver: "warning"
      repeat_interval: 4h

    - match:
        severity: info
      receiver: "info"
      repeat_interval: 24h

inhibit_rules:
  # Se il server è down, silenzia tutti gli altri alert dallo stesso server
  - source_match:
      alertname: NodeDown
    target_match_re:
      alertname: ".+"
    equal: ["instance"]

  # Se BIND è down, silenzia alert sul query rate
  - source_match:
      alertname: BINDDown
    target_match_re:
      alertname: "BIND.+"
    equal: ["instance"]

receivers:
  - name: "default"
{% if alertmanager_smtp_enabled %}
    email_configs:
      - to: "{{ alertmanager_smtp_to }}"
        send_resolved: true
        headers:
          Subject: "[DNS] {{ '{{' }} .GroupLabels.alertname {{ '}}' }} — {{ '{{' }} .CommonAnnotations.summary {{ '}}' }}"
{% endif %}
{% if alertmanager_webhook_enabled %}
    webhook_configs:
      - url: "{{ alertmanager_webhook_url }}"
        send_resolved: true
{% endif %}

  - name: "critical"
{% if alertmanager_smtp_enabled %}
    email_configs:
      - to: "{{ alertmanager_smtp_to }}"
        send_resolved: true
        headers:
          Subject: "[DNS CRITICAL] {{ '{{' }} .GroupLabels.alertname {{ '}}' }}"
{% endif %}
{% if alertmanager_webhook_enabled %}
    webhook_configs:
      - url: "{{ alertmanager_webhook_url }}"
        send_resolved: true
{% endif %}

  - name: "warning"
{% if alertmanager_smtp_enabled %}
    email_configs:
      - to: "{{ alertmanager_smtp_to }}"
        send_resolved: true
{% endif %}

  - name: "info"
{% if alertmanager_smtp_enabled %}
    email_configs:
      - to: "{{ alertmanager_smtp_to }}"
        send_resolved: false
{% endif %}
