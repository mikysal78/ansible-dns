{
  "title": "DNS Servers — System Health",
  "uid": "dns-system",
  "tags": ["system", "node"],
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-3h", "to": "now" },
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Nodes Up",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "targets": [{ "expr": "count(up{job=\"node\"} == 1)" }],
      "fieldConfig": { "defaults": { "thresholds": {
        "steps": [{"color": "red", "value": null}, {"color": "green", "value": 1}]
      }}}
    },
    {
      "id": 2, "type": "timeseries", "title": "CPU Usage per Node",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [{
        "expr": "100 - (avg by(instance)(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
        "legendFormat": "{{instance}}"
      }],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 }}
    },
    {
      "id": 3, "type": "timeseries", "title": "Memory Usage per Node",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [{
        "expr": "(node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes) / node_memory_MemTotal_bytes * 100",
        "legendFormat": "{{instance}}"
      }],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 }}
    },
    {
      "id": 4, "type": "timeseries", "title": "Network Traffic (DNS UDP)",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [
        { "expr": "rate(node_network_receive_bytes_total[5m])", "legendFormat": "rx {{instance}}" },
        { "expr": "rate(node_network_transmit_bytes_total[5m])", "legendFormat": "tx {{instance}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps" }}
    },
    {
      "id": 5, "type": "timeseries", "title": "Disk I/O",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [
        { "expr": "rate(node_disk_read_bytes_total[5m])", "legendFormat": "read {{instance}}" },
        { "expr": "rate(node_disk_written_bytes_total[5m])", "legendFormat": "write {{instance}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps" }}
    }
  ]
}
