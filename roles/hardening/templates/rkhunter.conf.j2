# /etc/rkhunter.conf.local
# Generato da Ansible — NON MODIFICARE MANUALMENTE
# Sovrascrive opzioni di /etc/rkhunter.conf

MAIL-ON-WARNING="{{ hardening_rkhunter_mail_to }}"
MAIL_CMD=mail -s "[rkhunter] {{ ansible_hostname }} warning"

# Segnala solo warning nel report (meno rumore)
REPORT_WARNINGS_ONLY=1

# SSH — coerente con la nostra configurazione
ALLOW_SSH_ROOT_USER={{ hardening_rkhunter_allow_ssh_root_user }}
ALLOW_SSH_PROT_V1=0

# Whitelist processi legittimi su un DNS server
EXISTWHITELIST=/usr/sbin/named
EXISTWHITELIST=/usr/sbin/sshd
EXISTWHITELIST=/usr/bin/fail2ban-server

# Whitelist script legittimi con attributo immutabile
ALLOWHIDDENFILE=/etc/.ansible_managed
ALLOWHIDDENDIR=/etc/.git

# Non controllare questi file (generati dinamicamente da BIND)
SKIPFILECHECK=/var/lib/bind/zones
SKIPFILECHECK=/var/cache/bind
