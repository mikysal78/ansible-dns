// /etc/apt/apt.conf.d/50unattended-upgrades
// Generato da Ansible — NON MODIFICARE MANUALMENTE

Unattended-Upgrade::Allowed-Origins {
    "${distro_id}:${distro_codename}";
    "${distro_id}:${distro_codename}-security";
    "${distro_id}ESMApps:${distro_codename}-apps-security";
    "${distro_id}ESM:${distro_codename}-infra-security";
};

// Solo aggiornamenti di sicurezza — NON aggiorna tutto
Unattended-Upgrade::Origins-Pattern {
    "origin=Debian,codename=${distro_codename},label=Debian-Security";
};

// Pacchetti da NON aggiornare automaticamente
// (aggiornamenti BIND9 richiedono test preventivo)
Unattended-Upgrade::Package-Blacklist {
    "bind9";
    "bind9utils";
};

Unattended-Upgrade::Mail "{{ hardening_unattended_upgrades_mail }}";
Unattended-Upgrade::MailReport "on-change";
Unattended-Upgrade::Remove-Unused-Dependencies {{ 'true' if hardening_unattended_upgrades_remove_deps else 'false' }};
Unattended-Upgrade::Remove-Unused-Kernel-Packages "true";

// MAI riavviare automaticamente un server DNS
Unattended-Upgrade::Automatic-Reboot {{ 'true' if hardening_unattended_upgrades_reboot else 'false' }};
Unattended-Upgrade::Automatic-Reboot-Time "{{ hardening_unattended_upgrades_reboot_time }}";

Unattended-Upgrade::SyslogEnable "true";
Unattended-Upgrade::SyslogFacility "daemon";
Unattended-Upgrade::Verbose "false";
