# /etc/audit/auditd.conf
# Generato da Ansible — NON MODIFICARE MANUALMENTE

log_file = /var/log/audit/audit.log
log_format = ENRICHED
log_group = adm
priority_boost = 4
flush = INCREMENTAL_ASYNC
freq = 50
max_log_file = {{ hardening_auditd_max_log_file }}
num_logs = 10
max_log_file_action = {{ hardening_auditd_max_log_file_action }}
space_left = 75
space_left_action = {{ hardening_auditd_space_left_action }}
action_mail_acct = {{ hardening_auditd_action_mail_acct }}
admin_space_left = 50
admin_space_left_action = {{ hardening_auditd_admin_space_left_action }}
disk_full_action = suspend
disk_error_action = suspend
tcp_listen_queue = 5
tcp_max_per_addr = 1
tcp_client_max_idle = 0
transport = TCP
krb5_principal = auditd
distribute_network = no
