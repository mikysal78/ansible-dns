# Ansible
*.retry
.cache/
.vault_pass
*.vault_pass

# === Secrets — MAI committare il vault reale ===
**/vault.yml
host_vars/*/vault.yml
# Il template .example DEVE essere committato (riferimento delle chiavi)
!**/vault.yml.example

# === Dati reali dell'infrastruttura — solo i .example vanno in git ===
inventory/hosts.yml
inventory/group_vars/all/main.yml
!inventory/hosts.yml.example
!inventory/group_vars/all/main.yml.example

# Zone reali (tieni solo gli esempi example.com)
zones/*.yml
!zones/example.com.yml
!zones/dyn.example.com.yml

# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/

# Molecule
molecule/**/molecule.yml.bak
.molecule/

# Editor
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Logs
*.log

# Temp
*.tmp

# Script di sessione locali (es. claude --resume)
resume.sh
