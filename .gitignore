# Ansible
*.retry
.cache/
.vault_pass
*.vault_pass

# Secrets — mai committare il vault reale
group_vars/all/vault.yml
host_vars/*/vault.yml
**/vault.yml

# Ma il template .example DEVE essere committato (riferimento delle chiavi)
!group_vars/all/vault.yml.example
!**/vault.yml.example

# Solo il template va in git, non il vault cifrato
# Procedura: cp vault.yml.example vault.yml && ansible-vault encrypt vault.yml

# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/

# Molecule
molecule/**/molecule.yml.bak
.molecule/

# Editor
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Logs
*.log

