---
# ============================================================
# INVENTORY DI ESEMPIO — copia in hosts.yml e adatta
#   cp inventory/hosts.yml.example inventory/hosts.yml
# ============================================================
all:
  children:
    # Nodo Proxmox VE — solo per creare il template e provisioning VM
    proxmox:
      hosts:
        pve:
          ansible_host: 10.0.0.5            # IP del nodo Proxmox
          ansible_user: root
          ansible_become: true

    # Hidden primary (dietro NAT, non pubblicato negli NS)
    dns_primary:
      hosts:
        ns-primary:
          ansible_host: 10.0.0.14          # IP privato/LAN del primary
          wg_address: 10.99.0.1            # IP nel tunnel WireGuard
          ansible_user: root
          ansible_become: true

    # Secondari pubblici (es. VPS cloud)
    dns_secondary:
      hosts:
        ns1:
          ansible_host: 203.0.113.10       # IP pubblico secondario 1
          wg_address: 10.99.0.2
          ansible_user: root
          ansible_become: true
          dns_secondary_index: 1
        ns2:
          ansible_host: 203.0.113.20       # IP pubblico secondario 2
          wg_address: 10.99.0.3
          ansible_user: root
          ansible_become: true
          dns_secondary_index: 2

    # CT dedicato allo stack di monitoring (Prometheus+Alertmanager+Grafana
    # dietro nginx :80). Peer WireGuard: scrapa gli exporter via tunnel.
    # Requisiti: Debian Trixie, CT unprivileged con nesting=1, 2GB RAM, 20GB.
    monitoring_server:
      hosts:
        ct-monitoring:
          ansible_host: 10.0.0.7
          ansible_user: root
          ansible_port: 2400
          ansible_become: true
          wg_address: 10.99.0.6

    # Host non-DNS che devono raggiungere il primary via WireGuard
    # (es. Proxmox/PBS per l'ACME built-in via nsupdate).
    # monitoring_server ci finisce come children: è peer per lo scraping.
    wg_extra_peers:
      children:
        proxmox:
        monitoring_server:
      hosts: {}
        # pbs:
        #   ansible_host: 10.0.0.4
        #   ansible_user: root
        #   ansible_become: true
        #   wg_address: 10.99.0.5

    # CT Proxmox che ricevono i certificati dal primary via deploy script
    # cert_domain: dominio il cui cert deve arrivare su questo CT
    # cert_reload_cmd: comando da eseguire dopo aver copiato il cert
    cert_consumers:
      hosts:
        ct-web:
          ansible_host: 10.0.0.16
          ansible_user: root
          ansible_port: 2400
          cert_domain: "example.com"
          cert_reload_cmd: "systemctl reload nginx"
        ct-mail:
          ansible_host: 10.0.0.6
          ansible_user: root
          ansible_port: 2400
          cert_domain: "example.com"
          cert_reload_cmd: "systemctl reload postfix && systemctl reload dovecot"

    # Router OpenWrt per DDNS (opzionale)
    openwrt_routers:
      hosts: {}
        # router-home:
        #   ansible_host: 192.168.1.1
        #   ansible_user: root
