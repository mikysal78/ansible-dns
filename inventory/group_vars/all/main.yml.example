---
# ============================================================
# VARIABILI GLOBALI — group_vars/all/main.yml
# ============================================================

# --- Identità DNS ---
dns_domain_base: "example.com"          # dominio principale
dns_admin_email: "hostmaster@example.com"

# --- IP hidden primary (usato dai secondari per AXFR) ---
dns_primary_ip: "10.99.0.1"
dns_primary_port: 53

# IP LAN del primary su cui BIND ascolta ANCHE per accettare nsupdate/DDNS
# dalla LAN interna (oltre a loopback e all'IP WireGuard dns_primary_ip).
# Lasciare vuoto ("") per non esporre BIND sull'interfaccia LAN.
dns_primary_lan_ip: ""

# --- IP pubblici dei secondari (lista) ---
dns_secondary_ips:
  - "203.0.113.10"
  - "203.0.113.20"

# --- TSIG key per trasferimenti sicuri ---
# Genera con: tsig-keygen -a hmac-sha256 axfr-key
# Il secret vero è in group_vars/all/vault.yml (cifrato)
dns_tsig_key_name: "axfr-key"
dns_tsig_algorithm: "hmac-sha256"
dns_tsig_secret: "{{ vault_tsig_secret }}"

# --- DDNS (per router OpenWrt) ---
ddns_key_name: "ddns-key"
ddns_algorithm: "hmac-sha256"
ddns_secret: "{{ vault_ddns_secret }}"
ddns_zone: "dyn.example.com"
ddns_ttl: 60

# IP/reti autorizzati a raggiungere la porta 53 (UDP/TCP) del primary per
# DDNS/nsupdate, oltre a 127.0.0.1 (sempre incluso). Accetta sia IP singoli
# che CIDR (nftables crea un interval set automaticamente).
#   - IP del tunnel WireGuard (10.99.0.0/24): es. l'ACME built-in di Proxmox
#     (plugin nsupdate) come peer WireGuard per la challenge DNS-01 del
#     certificato della propria interfaccia web (vedi inventory/hosts.yml).
#   - CIDR di LAN interna: client nsupdate che aggiornano la zona dyn. Richiede
#     che BIND ascolti anche sull'IP LAN (dns_primary_lan_ip) e che gli update
#     restino autenticati via TSIG key (allow-update { key ... }).
ddns_allowed_sources:
  - "10.99.0.4"
  # - "10.27.0.0/16"

# --- ACME / Let's Encrypt ---
acme_email: "admin@example.com"
acme_server: "https://acme-v02.api.letsencrypt.org/directory"  # prod
# acme_server: "https://acme-staging-v02.api.letsencrypt.org/directory"  # staging
acme_install_dir: "/opt/acme.sh"
acme_certs_dir: "/etc/ssl/acme"
acme_reload_cmd: "systemctl reload bind9"
acme_version: "3.1.3"


# --- Zone da servire (lista dei file in zones/) ---
# Directory radice del progetto dove si trovano i file zona YAML.
# I playbook stanno in playbooks/, quindi la root è un livello sopra.
dns_zones_dir_src: "{{ playbook_dir }}/.."

dns_zones:
  - name: "example.com"
    file: "zones/example.com.yml"
    type: "master"
    ddns_enabled: false
  - name: "dyn.example.com"
    file: "zones/dyn.example.com.yml"
    type: "master"
    ddns_enabled: true

# --- Zone REVERSE automatiche (notazione CIDR) ---
# Dichiari solo il CIDR: zone_name e PTR calcolati automaticamente
# dai record A/AAAA delle zone dirette. IPv4 /8 /16 /24, IPv6 multiplo di 4.
dns_reverse_zones:
  - cidr:       "10.0.0.0/16"
    primary_ns: "dns.example.com."
    admin:      "hostmaster.example.com."
    ttl:        3600
    ns:
      - "ns1.example.com."
      - "ns2.example.com."

# Chiave SSH usata dal primary per copiare i cert ai CT consumer
acme_deploy_key: "/root/.ssh/acme_deploy_id_ed25519"
acme_deploy_ssh_port: 2400   # porta SSH dei CT consumer

# Domini per cui ottenere i certificati wildcard Let's Encrypt.
# Campo "deploy" opzionale: lista di CT a cui distribuire il cert al rinnovo.
acme_domains:
  - domain: "example.com"
    keylength: "ec-256"
    # deploy:
    #   - host: "10.0.0.16"
    #     reload_cmd: "systemctl reload nginx"

# --- Bind9 ---
bind_user: "bind"
bind_group: "bind"
bind_config_dir: "/etc/bind"
bind_zones_dir: "/var/lib/bind/zones"
bind_log_dir: "/var/log/named"

# ---Proxmox ---
proxmox_host:          "10.0.0.5"
proxmox_node:          "pve"
proxmox_storage:       "storage"
proxmox_bridge:        "vmbr0"
proxmox_template_vmid: 9000
proxmox_primary_vmid:  100
proxmox_primary_ip:    "10.0.0.14"
proxmox_primary_gw:    "10.0.0.5"


# --- SSH: accesso root in locale (host non esposti su Internet) ---
# hardening_ssh_permit_root: "yes"
# hardening_ssh_port: 2400
# hardening_ssh_allow_tcp_forwarding: "yes"
# hardening_ssh_permit_open:
#   - "127.0.0.1:3000"
#   - "127.0.0.1:9090"

# nftables deve aprire la porta SSH reale (hardening la sposta su 2400)
# nft_ssh_port: "{{ hardening_ssh_port }}"

# --- Monitoring (CT dedicato: ct-monitoring) ---
# Sorgenti autorizzate alle GUI Grafana/Prometheus/Alertmanager
# (nftables sul CT; i servizi ascoltano solo su loopback dietro nginx :80)
monitoring_allowed_sources:
  - "127.0.0.1"
  - "10.0.0.0/24"     # LAN di gestione

# Le GUI rispondono senza porta: nginx smista per nome host.
# DNS: grafana → A <ip del CT>, prometheus/alertmanager → CNAME grafana
grafana_domain: "grafana.example.com"
grafana_root_url: "http://grafana.example.com/"
prometheus_domain: "prometheus.example.com"
alertmanager_domain: "alertmanager.example.com"
